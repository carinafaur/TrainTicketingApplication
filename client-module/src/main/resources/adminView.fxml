<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?> <?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.AdminController">
    <top>
        <VBox spacing="10" style="-fx-background-color: #2c3e50; -fx-padding: 15;">
            <HBox alignment="CENTER_LEFT" spacing="20">
                <Label text="Admin Panel" textFill="WHITE">
                    <font>
                        <Font name="System Bold" size="24.0" />
                    </font>
                </Label>
                <HBox alignment="CENTER_RIGHT" HBox.hgrow="ALWAYS">
                    <Button fx:id="logoutButton" onAction="#handleLogout" style="-fx-background-color: #e67e22; -fx-text-fill: white;" text="Logout" />
                </HBox>
            </HBox>
        </VBox>
    </top>

    <center>
        <VBox spacing="15" style="-fx-padding: 20;">
            <VBox spacing="10" style="-fx-border-color: #bdc3c7; -fx-border-radius: 5; -fx-padding: 15; -fx-background-color: #f9f9f9;">
                <Label style="-fx-font-weight: bold; -fx-font-size: 14;" text="Add/Modify Route" />

                <HBox alignment="CENTER_LEFT" spacing="15">
                    <VBox spacing="5">
                        <Label text="Start Station:" />
                        <ComboBox fx:id="startStationCombo" prefWidth="180.0" promptText="Select Start Station" />
                    </VBox>

                    <VBox spacing="5">
                        <Label text="End Station:" />
                        <ComboBox fx:id="endStationCombo" prefWidth="180.0" promptText="Select Destination" />
                    </VBox>
                </HBox>

                <HBox spacing="10" style="-fx-padding: 10 0 0 0;">
                    <Button onAction="#handleAddRoute" style="-fx-padding: 8 15; -fx-font-size: 12; -fx-background-color: #27ae60; -fx-text-fill: white;" text="Add Route" />
                    <Button onAction="#handleUpdateRoute" style="-fx-padding: 8 15; -fx-font-size: 12;" text="Modify Route" />
                    <Button onAction="#handleDeleteRoute" style="-fx-padding: 8 15; -fx-font-size: 12; -fx-text-fill: white; -fx-background-color: #e74c3c;" text="Delete Route" />
                </HBox>
            </VBox>

            <VBox spacing="10" style="-fx-border-color: #bdc3c7; -fx-border-radius: 5; -fx-padding: 15;" VBox.vgrow="ALWAYS">
                <Label style="-fx-font-weight: bold; -fx-font-size: 14;" text="List of Routes" />

                <TableView fx:id="routesTable" prefHeight="400" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="routeIdColumn" prefWidth="80" text="ID" />
                        <TableColumn fx:id="routeStartColumn" prefWidth="200" text="Start Station" />
                        <TableColumn fx:id="routeEndColumn" prefWidth="200" text="End Station" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>

                <Label fx:id="messageLabel" style="-fx-font-size: 12;" textFill="#27ae60" />
            </VBox>
        </VBox>
    </center>
</BorderPane>