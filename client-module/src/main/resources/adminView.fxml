<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="gui.AdminController"
            stylesheets="@styles.css"
            prefWidth="1100" prefHeight="720">

    <top>
        <HBox styleClass="app-header" alignment="CENTER_LEFT" spacing="14">
            <VBox spacing="2">
                <Label styleClass="app-title" text="Admin Panel" />
                <Label fx:id="welcomeLabel" styleClass="app-subtitle" text="Manage routes, trains and schedules" />
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
            <Button fx:id="logoutButton" styleClass="btn,btn-ghost" text="Logout" onAction="#handleLogout"/>
        </HBox>
    </top>

    <center>
        <TabPane fx:id="tabPane" tabClosingPolicy="UNAVAILABLE">

            <!-- ====================== ROUTES ====================== -->
            <Tab text="Routes">
                <VBox spacing="16">
                    <padding><Insets top="20" right="24" bottom="20" left="24"/></padding>

                    <VBox styleClass="card" spacing="12">
                        <Label styleClass="card-title" text="Add or modify a route"/>
                        <Label styleClass="card-hint" text="Pick the start and end stations, then use one of the actions."/>
                        <HBox spacing="14" alignment="CENTER_LEFT">
                            <VBox spacing="4">
                                <Label text="Start station"/>
                                <ComboBox fx:id="startStationCombo" prefWidth="220" promptText="Select start"/>
                            </VBox>
                            <VBox spacing="4">
                                <Label text="End station"/>
                                <ComboBox fx:id="endStationCombo" prefWidth="220" promptText="Select destination"/>
                            </VBox>
                        </HBox>
                        <HBox spacing="10">
                            <Button styleClass="btn,btn-success"   text="Add route"    onAction="#handleAddRoute"/>
                            <Button styleClass="btn,btn-primary"   text="Modify route" onAction="#handleUpdateRoute"/>
                            <Button styleClass="btn,btn-danger"    text="Delete route" onAction="#handleDeleteRoute"/>
                            <Button styleClass="btn,btn-secondary" text="Clear form"   onAction="#handleClearRouteForm"/>
                        </HBox>
                    </VBox>

                    <VBox styleClass="card" spacing="10" VBox.vgrow="ALWAYS">
                        <Label styleClass="card-title" text="All routes"/>
                        <TableView fx:id="routesTable" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="routeIdColumn"    prefWidth="80"  text="ID"/>
                                <TableColumn fx:id="routeStartColumn" prefWidth="280" text="Start station"/>
                                <TableColumn fx:id="routeEndColumn"   prefWidth="280" text="End station"/>
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                            </columnResizePolicy>
                        </TableView>
                        <Label fx:id="messageLabel" styleClass="status-ok"/>
                    </VBox>
                </VBox>
            </Tab>

            <!-- ====================== TRAINS ====================== -->
            <Tab text="Trains">
                <VBox spacing="16">
                    <padding><Insets top="20" right="24" bottom="20" left="24"/></padding>

                    <VBox styleClass="card" spacing="12">
                        <Label styleClass="card-title" text="Add, modify or remove a train"/>
                        <Label styleClass="card-hint" text="Train number must be unique. Capacity must be a positive integer."/>
                        <HBox spacing="14" alignment="CENTER_LEFT">
                            <VBox spacing="4">
                                <Label text="Train number"/>
                                <TextField fx:id="trainNumberField" prefWidth="220" promptText="e.g. IR-372"/>
                            </VBox>
                            <VBox spacing="4">
                                <Label text="Capacity"/>
                                <Spinner fx:id="trainCapacitySpinner" prefWidth="140" editable="true"/>
                            </VBox>
                        </HBox>
                        <HBox spacing="10">
                            <Button styleClass="btn,btn-success"   text="Add train"     onAction="#handleAddTrain"/>
                            <Button styleClass="btn,btn-primary"   text="Modify train"  onAction="#handleUpdateTrain"/>
                            <Button styleClass="btn,btn-danger"    text="Delete train"  onAction="#handleDeleteTrain"/>
                            <Button styleClass="btn,btn-secondary" text="Clear form"    onAction="#handleClearTrainForm"/>
                        </HBox>
                    </VBox>

                    <VBox styleClass="card" spacing="10" VBox.vgrow="ALWAYS">
                        <Label styleClass="card-title" text="All trains"/>
                        <Label styleClass="card-hint" text="Click a row to load it into the form above."/>
                        <TableView fx:id="trainsTable" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="trainIdColumn"       prefWidth="80"  text="ID"/>
                                <TableColumn fx:id="trainNumberColumn"   prefWidth="280" text="Train number"/>
                                <TableColumn fx:id="trainCapacityColumn" prefWidth="280" text="Capacity"/>
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                            </columnResizePolicy>
                        </TableView>
                        <Label fx:id="trainMessageLabel" styleClass="status-ok"/>
                    </VBox>
                </VBox>
            </Tab>

            <!-- ====================== STATIONS ====================== -->
            <Tab text="Stations">
                <VBox spacing="16">
                    <padding><Insets top="20" right="24" bottom="20" left="24"/></padding>

                    <VBox styleClass="card" spacing="12">
                        <Label styleClass="card-title" text="Add, modify or remove a station"/>
                        <Label styleClass="card-hint" text="City and name are mandatory. Each (city, name) pair must be unique."/>
                        <HBox spacing="14" alignment="CENTER_LEFT">
                            <VBox spacing="4">
                                <Label text="City"/>
                                <TextField fx:id="stationCityField" prefWidth="220" promptText="e.g. Bucharest"/>
                            </VBox>
                            <VBox spacing="4">
                                <Label text="Station name"/>
                                <TextField fx:id="stationNameField" prefWidth="260" promptText="e.g. Bucharest North"/>
                            </VBox>
                        </HBox>
                        <HBox spacing="10">
                            <Button styleClass="btn,btn-success"   text="Add station"     onAction="#handleAddStation"/>
                            <Button styleClass="btn,btn-primary"   text="Modify station"  onAction="#handleUpdateStation"/>
                            <Button styleClass="btn,btn-danger"    text="Delete station"  onAction="#handleDeleteStation"/>
                            <Button styleClass="btn,btn-secondary" text="Clear form"      onAction="#handleClearStationForm"/>
                        </HBox>
                    </VBox>

                    <VBox styleClass="card" spacing="10" VBox.vgrow="ALWAYS">
                        <Label styleClass="card-title" text="All stations"/>
                        <Label styleClass="card-hint" text="Click a row to load it into the form above."/>
                        <TableView fx:id="stationsTable" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="stationIdColumn"   prefWidth="80"  text="ID"/>
                                <TableColumn fx:id="stationCityColumn" prefWidth="220" text="City"/>
                                <TableColumn fx:id="stationNameColumn" prefWidth="280" text="Station name"/>
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                            </columnResizePolicy>
                        </TableView>
                        <Label fx:id="stationMessageLabel" styleClass="status-ok"/>
                    </VBox>
                </VBox>
            </Tab>

            <!-- ====================== SCHEDULES ====================== -->
            <Tab text="Schedules">
                <VBox spacing="16">
                    <padding><Insets top="20" right="24" bottom="20" left="24"/></padding>

                    <VBox styleClass="card" spacing="12">
                        <Label styleClass="card-title" text="Create a new schedule"/>
                        <Label styleClass="card-hint" text="Pick a train and a route, then continue to add stops and times."/>
                        <HBox spacing="14" alignment="CENTER_LEFT">
                            <VBox spacing="4">
                                <Label text="Train"/>
                                <ComboBox fx:id="scheduleTrainCombo" prefWidth="220" promptText="Select train"/>
                            </VBox>
                            <VBox spacing="4">
                                <Label text="Route"/>
                                <ComboBox fx:id="scheduleRouteCombo" prefWidth="280" promptText="Select route"/>
                            </VBox>
                        </HBox>
                        <HBox spacing="10">
                            <Button styleClass="btn,btn-success"   text="Continue → add stops..." onAction="#handleStartNewSchedule"/>
                        </HBox>
                    </VBox>

                    <VBox styleClass="card" spacing="10" VBox.vgrow="ALWAYS">
                        <Label styleClass="card-title" text="All schedules"/>
                        <Label styleClass="card-hint" text="Click a row to select. Use the buttons below to edit or delete."/>
                        <TableView fx:id="schedulesTable" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="schedIdColumn"        prefWidth="60"  text="ID"/>
                                <TableColumn fx:id="schedTrainColumn"     prefWidth="120" text="Train"/>
                                <TableColumn fx:id="schedRouteColumn"     prefWidth="220" text="Route"/>
                                <TableColumn fx:id="schedDepartureColumn" prefWidth="160" text="Departure"/>
                                <TableColumn fx:id="schedArrivalColumn"   prefWidth="160" text="Arrival"/>
                                <TableColumn fx:id="schedStopsColumn"     prefWidth="80"  text="Stops"/>
                                <TableColumn fx:id="schedDelayColumn"     prefWidth="80"  text="Delay"/>
                                <TableColumn fx:id="schedStatusColumn"    prefWidth="120" text="Status"/>
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                            </columnResizePolicy>
                        </TableView>
                        <HBox spacing="10">
                            <Button styleClass="btn,btn-primary" text="Edit selected"   onAction="#handleEditSchedule"/>
                            <Button styleClass="btn,btn-danger"  text="Delete selected" onAction="#handleDeleteSchedule"/>
                        </HBox>
                        <Label fx:id="scheduleMessageLabel" styleClass="status-ok"/>
                    </VBox>
                </VBox>
            </Tab>

            <!-- ====================== BOOKINGS ====================== -->
            <Tab text="Bookings">
                <VBox spacing="16">
                    <padding><Insets top="20" right="24" bottom="20" left="24"/></padding>

                    <VBox styleClass="card" spacing="10">
                        <Label styleClass="card-title" text="Filter"/>
                        <HBox spacing="14" alignment="CENTER_LEFT">
                            <VBox spacing="4">
                                <Label text="Train"/>
                                <ComboBox fx:id="bookingsTrainFilter" prefWidth="220" promptText="All trains"/>
                            </VBox>
                            <VBox spacing="4" alignment="BOTTOM_LEFT">
                                <Label text=" "/>
                                <Button styleClass="btn,btn-secondary" text="Clear filter" onAction="#handleClearBookingsFilter"/>
                            </VBox>
                        </HBox>
                    </VBox>

                    <VBox styleClass="card" spacing="10" VBox.vgrow="ALWAYS">
                        <Label styleClass="card-title" text="All bookings"/>
                        <Label fx:id="bookingsHint" styleClass="card-hint"/>
                        <TableView fx:id="bookingsTable" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="bookIdColumn"        prefWidth="60"  text="ID"/>
                                <TableColumn fx:id="bookUserColumn"      prefWidth="120" text="User"/>
                                <TableColumn fx:id="bookTrainColumn"     prefWidth="100" text="Train"/>
                                <TableColumn fx:id="bookFromColumn"      prefWidth="160" text="From"/>
                                <TableColumn fx:id="bookToColumn"        prefWidth="160" text="To"/>
                                <TableColumn fx:id="bookDepartureColumn" prefWidth="140" text="Departure"/>
                                <TableColumn fx:id="bookSeatsColumn"     prefWidth="80"  text="Seats"/>
                                <TableColumn fx:id="bookBookedAtColumn"  prefWidth="140" text="Booked at"/>
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                            </columnResizePolicy>
                        </TableView>
                    </VBox>
                </VBox>
            </Tab>

        </TabPane>
    </center>
</BorderPane>
